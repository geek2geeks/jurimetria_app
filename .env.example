# Chaves de API e variáveis de ambiente
DEEPSEEK_CHAVE_API=coloca_aqui_a_chave_de_api_deepseek
DEEPSEEK_URL_BASE=https://api.deepseek.com
DEEPSEEK_MODELO=deepseek-v4-pro

# Origem do conjunto de dados
URL_CONJUNTO_DADOS=https://drive.google.com/file/d/1n3XGcyk1ZoSf5vbaQYhZ5BGivebt98WG/view?usp=sharing

# Jira Cloud - copia este ficheiro para .env e substitui os marcadores localmente
JIRA_URL_BASE=https://fixola198.atlassian.net
JIRA_CHAVE_PROJETO=SCRUM
JIRA_EMAIL=teu_email_atlassian@example.com
JIRA_TOKEN_API=coloca_aqui_o_token_de_api_jira
JIRA_FICHEIRO_MEMBROS=membros_jira.json
JIRA_FICHEIRO_RESPONSAVEIS=responsaveis_jira.json

# -----------------------------------------------------------------------
# P7 — Módulo de inferência (Sandro / SCRUM-11)
# -----------------------------------------------------------------------
# Identificador da execução treinada: artefactos/<ID_EXECUCAO>/manifesto.json
ID_EXECUCAO=execucao_teste
PASTA_ARTEFACTOS=artefactos
PASTA_DADOS=data

# Layout da saída no terminal: texto | markdown | json
FORMATO_SAIDA=texto

# Exportar resumo executivo (caminho com extensão .txt/.md/.json/.html); vazio = não exportar
EXPORTAR_RESUMO=

# Vertente "Could Have" — explicação via LLM (false = sem rede, padrão seguro)
EXPLICACAO_VIA_LLM=false
LLM_TEMPO_LIMITE_SEGUNDOS=20

# GPU NVIDIA — opcional (false = CPU)
GPU_HABILITADA=false
GPU_NUM_DISPOSITIVOS=1
GPU_DISPOSITIVOS=auto
