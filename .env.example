# -----------------------------------------------------------------------
# EXECUÇÃO (obrigatório)
# -----------------------------------------------------------------------
# Identificador da pasta de artefactos treinados a usar.
# Estrutura esperada: artefactos/<ID_EXECUCAO>/manifesto.json
# ex: ID_EXECUCAO=execucao_001
ID_EXECUCAO=execucao_teste

# Pasta-mãe das execuções.
PASTA_ARTEFACTOS=artefactos

# -----------------------------------------------------------------------
# DADOS (obrigatório para o CLI)
# -----------------------------------------------------------------------
# Pasta onde estão os JSONs dos acórdãos reais.
# O CLI vai processar TODOS os .json desta pasta em sequência.
PASTA_DADOS=data/STA/

# -----------------------------------------------------------------------
# EXPORTAÇÃO DO RESUMO EXECUTIVO (opcional)
# -----------------------------------------------------------------------
# Caminho de saída do resumo. Vazio = não exportar; só exibe no terminal.
# Formato deduzido pela extensão:
#   .txt / .md  → texto plano
#   .json       → dados estruturados
#   .html       → relatório dark interactivo (gráficos donut + barras)
# Exemplos:
#   EXPORTAR_RESUMO=relatorios/resumo.html
#   EXPORTAR_RESUMO=relatorios/resumo.json
EXPORTAR_RESUMO=

# -----------------------------------------------------------------------
# GPU — NVIDIA multi-GPU (opcional; false = só CPU)
# -----------------------------------------------------------------------
# Topologia real (verificada com nvidia-smi -L):
#   cuda:0  — RTX 3070    (8 GB)   UUID: GPU-b0521959-d7d6-0f93-76da-6d2512f04502
#   cuda:1  — RTX 3080 Ti (12 GB)  UUID: GPU-02e1a01f-df1d-98c2-f712-021886b4ab12
#   cuda:2  — RTX 3080 Ti (12 GB)  UUID: GPU-273f3bda-4389-7d52-9681-e01eb2ab149c

CUDA_DEVICE_ORDER=PCI_BUS_ID
CUDA_VISIBLE_DEVICES=
GPU_HABILITADA=false
GPU_NUM_DISPOSITIVOS=1
GPU_DISPOSITIVOS=0

# --- Vertente SECUNDÁRIA (Could Have) — explicação via LLM ----------
# false (padrão) = explicação local determinística, sem rede.
# true           = pede o texto a um LLM remoto via OpenRouter.
EXPLICACAO_VIA_LLM=false

# Layout da saída no terminal:
#   texto    (padrão; prosa para terminal)
#   markdown (ficheiro/relatório)
#   json     (consumir por outro programa)
FORMATO_SAIDA=texto

# Tempo máximo de espera pela resposta do LLM (segundos):
LLM_TEMPO_LIMITE_SEGUNDOS=20


# Chaves de API e variáveis de ambiente
DEEPSEEK_CHAVE_API=
DEEPSEEK_URL_BASE=https://openrouter.ai
DEEPSEEK_MODELO=deepseek/deepseek-v4-flash

# Origem do conjunto de dados
URL_CONJUNTO_DADOS=

# Jira Cloud - copia este ficheiro para .env e substitui os marcadores localmente
JIRA_URL_BASE=https://fixola198.atlassian.net
JIRA_CHAVE_PROJETO=SCRUM
JIRA_EMAIL=
JIRA_TOKEN_API=
JIRA_FICHEIRO_MEMBROS=membros_jira.json
JIRA_FICHEIRO_RESPONSAVEIS=responsaveis_jira.json
